generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Course {
  id          String    @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bundles     Bundle[]
  sessions    Session[]
}

model Bundle {
  id               String      @id @default(cuid())
  courseId         String
  course           Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  position         Int
  title            String
  articleTitles    String[]
  themes           String[]
  generatedContent String      @db.Text
  published        Boolean     @default(false)
  publishedAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  messages          Message[]
  highlights        Highlight[]
  referencingBeats  Beat[]      @relation("BeatBundleRef")
  expandedFromBeats Beat[]      @relation("BeatExpandedBundle")
}

model Highlight {
  id               String   @id @default(cuid())
  bundleId         String
  bundle           Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  anchorText       String   @db.Text
  color            String   @default("yellow")
  note             String?  @db.Text
  position         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  referencingBeats Beat[]
}

model Message {
  id        String   @id @default(cuid())
  bundleId  String
  bundle    Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  role      String
  content   String   @db.Text
  mode      String   @default("refine")
  createdAt DateTime @default(now())
}

model Session {
  id          String    @id @default(cuid())
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  position    Int
  title       String
  description String?   @db.Text
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  beats       Beat[]
}

model Beat {
  id           String     @id @default(cuid())
  sessionId    String
  session      Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  position     Int
  kind         String
  slideType    String?
  title        String?
  outline      String?    @db.Text
  generated    Json?
  generatedAt  DateTime?
  bundleId         String?
  bundle           Bundle?    @relation("BeatBundleRef", fields: [bundleId], references: [id], onDelete: SetNull)
  sectionKey       String?
  highlightId      String?
  highlight        Highlight? @relation(fields: [highlightId], references: [id], onDelete: SetNull)
  expandedBundleId String?
  expandedBundle   Bundle?    @relation("BeatExpandedBundle", fields: [expandedBundleId], references: [id], onDelete: SetNull)
  speakerNotes String?    @db.Text
  sequenceId   String?
  messages     BeatMessage[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([sessionId, sequenceId])
}

model BeatMessage {
  id        String   @id @default(cuid())
  beatId    String
  beat      Beat     @relation(fields: [beatId], references: [id], onDelete: Cascade)
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())
}

model Article {
  id          String             @id @default(cuid())
  date        String
  section     String
  title       String
  author      String?
  themes      Json               @default("{}")
  source      String             @default("user")
  description String?
  url         String?
  sourceId    String?
  contentType String             @default("news")
  status      String             @default("accepted")
  abstract    String?            @db.Text
  fullText    String?            @db.Text
  summary     String?            @db.Text
  reviewedAt  DateTime?
  ingestedAt  DateTime           @default(now())
  createdAt   DateTime           @default(now())
  topics      TopicArticle[]
  embeddings  ArticleEmbedding[]
  supports    ArticleSupport[]

  @@unique([source, sourceId])
  @@map("UserArticle")
}

model Topic {
  id           String         @id @default(cuid())
  name         String         @unique
  description  String         @db.Text
  ingestConfig Json
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  articles     TopicArticle[]
  insights     InsightTopic[]
}

model Insight {
  id            String           @id @default(cuid())
  title         String
  slug          String           @unique
  stance        String           @default("working_hypothesis")
  bottomLine    String           @default("") @db.Text
  rationale     String           @default("") @db.Text
  openQuestions String           @default("") @db.Text
  author        String           @default("human")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  topics        InsightTopic[]
  supports      ArticleSupport[]
}

model InsightTopic {
  insightId String
  topicId   String
  insight   Insight @relation(fields: [insightId], references: [id], onDelete: Cascade)
  topic     Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([insightId, topicId])
}

model ArticleSupport {
  insightId String
  articleId String
  insight   Insight  @relation(fields: [insightId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  relevance String   @default("supports")
  excerpt   String?  @db.Text
  addedAt   DateTime @default(now())

  @@id([insightId, articleId])
}

model TopicArticle {
  topicId    String
  articleId  String
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([topicId, articleId])
}

model ArticleEmbedding {
  id         String                      @id @default(cuid())
  articleId  String
  article    Article                     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  chunkIndex Int                         @default(0)
  text       String                      @db.Text
  embedding  Unsupported("vector(1536)")
  createdAt  DateTime                    @default(now())

  @@unique([articleId, chunkIndex])
}
