generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Course {
  id          String    @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bundles     Bundle[]
  sessions    Session[]
}

model Bundle {
  id               String      @id @default(cuid())
  courseId         String
  course           Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  position         Int
  title            String
  articleTitles    String[]
  themes           String[]
  generatedContent String      @db.Text
  published        Boolean     @default(false)
  publishedAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  messages          Message[]
  highlights        Highlight[]
  referencingBeats  Beat[]      @relation("BeatBundleRef")
  expandedFromBeats Beat[]      @relation("BeatExpandedBundle")
}

model Highlight {
  id               String   @id @default(cuid())
  bundleId         String
  bundle           Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  anchorText       String   @db.Text
  color            String   @default("yellow")
  note             String?  @db.Text
  position         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  referencingBeats Beat[]
}

model Message {
  id        String   @id @default(cuid())
  bundleId  String
  bundle    Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  role      String
  content   String   @db.Text
  mode      String   @default("refine")
  createdAt DateTime @default(now())
}

model Session {
  id          String    @id @default(cuid())
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  position    Int
  title       String
  description String?   @db.Text
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  beats       Beat[]
}

model Beat {
  id           String     @id @default(cuid())
  sessionId    String
  session      Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  position     Int
  kind         String
  slideType    String?
  title        String?
  outline      String?    @db.Text
  generated    Json?
  generatedAt  DateTime?
  bundleId         String?
  bundle           Bundle?    @relation("BeatBundleRef", fields: [bundleId], references: [id], onDelete: SetNull)
  sectionKey       String?
  highlightId      String?
  highlight        Highlight? @relation(fields: [highlightId], references: [id], onDelete: SetNull)
  expandedBundleId String?
  expandedBundle   Bundle?    @relation("BeatExpandedBundle", fields: [expandedBundleId], references: [id], onDelete: SetNull)
  speakerNotes String?    @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model UserArticle {
  id          String   @id @default(cuid())
  date        String
  section     String
  title       String
  author      String?
  themes      Json     @default("{}")
  source      String   @default("user")
  description String?
  url         String?
  sourceId    String?
  ingestedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([source, sourceId])
}

model Todo {
  id        String   @id @default(cuid())
  text      String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
